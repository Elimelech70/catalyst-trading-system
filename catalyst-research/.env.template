# ---------- Existing intl-trading variables (already on the droplet) -----------
# Listed here so a builder can see the full picture. Do not duplicate-define.
# INTL_DATABASE_URL=postgres://catalyst_trading_writer:CHANGEME@HOST:25060/catalyst_intl?sslmode=require
# MOOMOO_HOST=127.0.0.1
# MOOMOO_PORT=11111

# ---------- New catalyst-research role-scoped connection strings ---------------
# All three target the SAME catalyst_intl database but as different roles.
# The role determines what each connection can read and write (RBAC).
RESEARCH_ADMIN_DATABASE_URL=postgres://catalyst_research_admin:CHANGEME@HOST:25060/catalyst_intl?sslmode=require
RESEARCH_INGESTION_DATABASE_URL=postgres://catalyst_research_ingestion:CHANGEME@HOST:25060/catalyst_intl?sslmode=require
RESEARCH_ARCHETYPE_DATABASE_URL=postgres://catalyst_research_archetype:CHANGEME@HOST:25060/catalyst_intl?sslmode=require

# ---------- Anthropic — archetype-only key, monthly cap set in console ---------
ANTHROPIC_API_KEY=sk-ant-CHANGEME

# ---------- Data source endpoints / keys ---------------------------------------
HKEX_FEED_URL=https://www1.hkexnews.hk/ncms/script/eds/eds_newsfile_en.json
UN_COMTRADE_API_KEY=                         # optional; raises rate limit if registered
BEA_API_KEY=CHANGEME                         # required for BEA US national-accounts ingestion

# ---------- Operational ---------------------------------------------------------
CR_LOG_DIR=/root/catalyst-research/logs
